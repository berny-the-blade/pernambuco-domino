        "discouraged_moves": [{ "tile": [4,5], "side": "left", "reason": "steals partner-signaled 4 line" }]
      },
      "tags": ["partner-play", "signaling", "suit-stealing"],
      "scoring": { "preferred_score": 1.0, "acceptable_score": 0.5, "discouraged_score": 0.0 }
    },
    {
      "id": "PARTNER_SUIT_STEAL_002",
      "theme": "dont_steal_partner_suit_forced_exception",
      "description": "Current player has no move except on partner's line, so stealing the suit is acceptable.",
      "player_to_move": 0,
      "team_to_move": 0,
      "board": { "left_end": 4, "right_end": 6, "board_length": 5,
        "history": [{ "player": 2, "tile": [4,2], "side": "left" }] },
      "hands": { "player_0": [[4,5],[4,6],[0,0],[1,1],[2,3],[3,5]], "player_1": [], "player_2": [], "player_3": [] },
      "hidden_info_mode": "partial",
      "cant_have": { "0": [], "1": [], "2": [], "3": [] },
      "expected": {
        "preferred_moves": [{ "tile": [4,5], "side": "left" }, { "tile": [4,6], "side": "left" }],
