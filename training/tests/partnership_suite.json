    {
      "id": "PARTNER_SIGNAL_CONFIRM_001",
      "theme": "confirm_partner_signal",
      "description": "Partner has just indicated comfort on 3; confirming that line is preferred over pivoting to a less informative side.",
      "player_to_move": 0,
      "team_to_move": 0,
      "board": { "left_end": 3, "right_end": 6, "board_length": 6,
        "history": [{ "player": 2, "tile": [3,1], "side": "left" }] },
      "hands": { "player_0": [[3,4],[6,2],[6,5],[0,0],[2,4],[1,1]], "player_1": [], "player_2": [], "player_3": [] },
      "hidden_info_mode": "partial",
      "cant_have": { "0": [], "1": [3], "2": [], "3": [] },
      "expected": {
        "preferred_moves": [{ "tile": [3,4], "side": "left" }],
        "acceptable_moves": [{ "tile": [6,2], "side": "right" }],
        "discouraged_moves": [{ "tile": [6,5], "side": "right", "reason": "ignores a fresh partner signal in favor of a blunter continuation" }]
      },
      "tags": ["signal-confirmation", "partnership", "duplas"],
      "scoring": { "preferred_score": 1.0, "acceptable_score": 0.5, "discouraged_score": 0.0 }
