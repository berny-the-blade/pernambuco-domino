        "discouraged_moves": []
      },
      "tags": ["partner-play", "forced-exception", "suit-stealing"],
      "scoring": { "preferred_score": 1.0, "acceptable_score": 0.5, "discouraged_score": 0.0 }
    },
    {
      "id": "PROBE_VOID_001",
      "theme": "information_probe",
      "description": "A probing move that preserves both uncertainty and pressure is preferred over a locally comfortable pip dump.",
      "player_to_move": 0,
      "team_to_move": 0,
      "board": { "left_end": 3, "right_end": 6, "board_length": 7,
        "history": [{ "player": 1, "tile": [6,2], "side": "right" }, { "player": 2, "tile": [3,4], "side": "left" }] },
      "hands": { "player_0": [[6,4],[6,1],[3,5],[0,0],[1,2],[2,5]], "player_1": [], "player_2": [], "player_3": [] },
      "hidden_info_mode": "partial",
      "cant_have": { "0": [], "1": [3], "2": [], "3": [6] },
      "expected": {
        "preferred_moves": [{ "tile": [3,5], "side": "left" }],
        "acceptable_moves": [{ "tile": [6,4], "side": "right" }],
        "discouraged_moves": [{ "tile": [6,1], "side": "right", "reason": "dumps a comfortable move without probing the contested left end" }]
      },
      "tags": ["information", "probing", "partnership"],
      "scoring": { "preferred_score": 1.0, "acceptable_score": 0.5, "discouraged_score": 0.0 }
    },
    {
      "id": "LOCK_SACRIFICE_001",
      "theme": "sacrifice_to_lock",
      "description": "A temporary pip-worse move is preferred because it preserves the locking line.",
      "player_to_move": 0,
      "team_to_move": 0,
      "board": { "left_end": 2, "right_end": 5, "board_length": 8,
        "history": [{ "player": 2, "tile": [5,0], "side": "right" }] },
      "hands": { "player_0": [[2,6],[2,1],[5,4],[1,1],[4,6],[0,3]], "player_1": [], "player_2": [], "player_3": [] },
      "hidden_info_mode": "partial",
      "cant_have": { "0": [], "1": [2], "2": [], "3": [5] },
      "expected": {
        "preferred_moves": [{ "tile": [2,1], "side": "left" }],
        "acceptable_moves": [{ "tile": [2,6], "side": "left" }],
        "discouraged_moves": [{ "tile": [5,4], "side": "right", "reason": "gives up the developing lock structure" }]
      },
      "tags": ["lock", "sacrifice", "structure"],
      "scoring": { "preferred_score": 1.0, "acceptable_score": 0.5, "discouraged_score": 0.0 }
    },
    {
      "id": "DAMAGE_CONTROL_001",
      "theme": "ad_hoc_teamplay",
      "description": "Partner has likely mis-signaled or broken structure; current player should switch to damage-control rather than continue the old plan.",
      "player_to_move": 0,
      "team_to_move": 0,
      "board": { "left_end": 1, "right_end": 4, "board_length": 9,
        "history": [{ "player": 2, "tile": [4,4], "side": "right" }, { "player": 3, "tile": [1,6], "side": "left" }] },
      "hands": { "player_0": [[1,5],[4,2],[4,6],[0,0],[2,3],[5,6]], "player_1": [], "player_2": [], "player_3": [] },
      "hidden_info_mode": "partial",
      "cant_have": { "0": [], "1": [], "2": [1], "3": [] },
      "expected": {
        "preferred_moves": [{ "tile": [1,5], "side": "left" }],
        "acceptable_moves": [{ "tile": [4,2], "side": "right" }],
        "discouraged_moves": [{ "tile": [4,6], "side": "right", "reason": "continues a broken line instead of damage control" }]
      },
      "tags": ["ad-hoc", "damage-control", "partnership"],
      "scoring": { "preferred_score": 1.0, "acceptable_score": 0.5, "discouraged_score": 0.0 }
    },
    {
      "id": "PRESSURE_END_001",
      "theme": "preserve_pressure",
      "description": "Keep the pressure end alive when opponents are more likely weak there.",
      "player_to_move": 2,
      "team_to_move": 0,
      "board": { "left_end": 0, "right_end": 6, "board_length": 6,
        "history": [{ "player": 1, "tile": [6,0], "side": "right" }] },
      "hands": { "player_0": [], "player_1": [], "player_2": [[0,4],[0,2],[6,5],[2,2],[1,4],[5,5]], "player_3": [] },
      "hidden_info_mode": "partial",
      "cant_have": { "0": [], "1": [0], "2": [], "3": [0] },
      "expected": {
        "preferred_moves": [{ "tile": [0,4], "side": "left" }, { "tile": [0,2], "side": "left" }],
        "acceptable_moves": [],
        "discouraged_moves": [{ "tile": [6,5], "side": "right", "reason": "removes the end opponents likely dislike" }]
      },
      "tags": ["pressure", "void-inference", "partnership"],
      "scoring": { "preferred_score": 1.0, "acceptable_score": 0.5, "discouraged_score": 0.0 }
    },
    {
      "id": "FORCED_PASS_AVOID_001",
      "theme": "maintain_partner_options",
      "description": "Choose the move that is more likely to leave partner a reply, rather than the move that collapses partner options.",
      "player_to_move": 0,
      "team_to_move": 0,
      "board": { "left_end": 2, "right_end": 3, "board_length": 10,
        "history": [{ "player": 2, "tile": [3,5], "side": "right" }] },
      "hands": { "player_0": [[2,4],[3,6],[2,5],[0,0],[1,1],[4,6]], "player_1": [], "player_2": [], "player_3": [] },
      "hidden_info_mode": "partial",
      "cant_have": { "0": [], "1": [], "2": [2], "3": [3] },
      "expected": {
        "preferred_moves": [{ "tile": [3,6], "side": "right" }],
        "acceptable_moves": [{ "tile": [2,4], "side": "left" }],
        "discouraged_moves": [{ "tile": [2,5], "side": "left", "reason": "likely leaves partner with fewer follow-ups" }]
      },
      "tags": ["partner-options", "coordination", "pressure"],
      "scoring": { "preferred_score": 1.0, "acceptable_score": 0.5, "discouraged_score": 0.0 }
    },
    {
      "id": "DOUBLE_SIDE_CONTROL_001",
      "theme": "double-side-control",
      "description": "When a double anchors one side, prefer moves that do not gratuitously restore the double side if a probing continuation exists.",
      "player_to_move": 2,
      "team_to_move": 0,
      "board": { "left_end": 6, "right_end": 2, "board_length": 4,
        "history": [{ "player": 0, "tile": [6,6], "side": "open" }, { "player": 1, "tile": [6,2], "side": "left" }] },
      "hands": { "player_0": [[6,6]], "player_1": [[6,2]], "player_2": [[2,4],[2,5],[6,1],[1,1],[3,4],[0,5]], "player_3": [] },
      "hidden_info_mode": "partial",
      "cant_have": { "0": [], "1": [], "2": [], "3": [] },
      "expected": {
        "preferred_moves": [{ "tile": [2,4], "side": "right" }, { "tile": [2,5], "side": "right" }],
        "acceptable_moves": [],
        "discouraged_moves": [{ "tile": [6,1], "side": "left", "reason": "gratuitously restores the double side instead of continuing the new end" }]
      },
      "tags": ["double", "new-end-preservation", "partnership"],
      "scoring": { "preferred_score": 1.0, "acceptable_score": 0.5, "discouraged_score": 0.0 }
    },
    {
      "id": "TACTICAL_OVERRIDE_001",
      "theme": "tactical_override",
      "description": "Normally preserving the new end is preferred, but here collapsing it is tactically correct because opponents are void on 1.",
      "player_to_move": 2,
      "team_to_move": 0,
      "board": { "left_end": 5, "right_end": 1, "board_length": 10,
        "history": [{ "player": 0, "tile": [5,5], "side": "open" }, { "player": 1, "tile": [5,1], "side": "left" }] },
      "hands": { "player_0": [], "player_1": [], "player_2": [[5,3],[1,4],[0,0],[2,2],[3,6],[4,6]], "player_3": [] },
      "hidden_info_mode": "partial",
      "cant_have": { "0": [], "1": [1], "2": [], "3": [1] },
      "expected": {
        "preferred_moves": [{ "tile": [5,3], "side": "left" }],
        "acceptable_moves": [{ "tile": [1,4], "side": "right" }],
        "discouraged_moves": []
      },
      "tags": ["override", "tactics", "new-end-preservation"],
